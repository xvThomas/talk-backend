# API keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here

# Tool execution configuration
# Maximum number of tools that can execute in parallel (default: 4)
# Set to 1 for sequential execution
TOOLS_MAX_CONCURRENT=4

# Context mode selector for conversation history:
# -1 => full message history, 
# 0 => lean (history turns + current turn details), default
# N>0 => hybrid with last N full turns
CONTEXT_FULL_TURNS=-1

# Langfuse observability configuration
# Get your API keys from https://langfuse.com project settings
# LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
# LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
# Base URL for Langfuse instance (default: https://cloud.langfuse.com for EU region)
# Use https://us.cloud.langfuse.com for US region, or your self-hosted URL
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Usage reporting configuration
# Enable/disable console usage reporter (default: true for backward compatibility)
# Set to false to disable console output when using only remote reporters
CONSOLE_USAGE_REPORTER=true

# CORS configuration for the AG-UI server (talk serve)
# CORS_ALLOW_ORIGIN=*
# CORS_ALLOW_HEADERS=Content-Type, Authorization
