FROM golang:1.25-alpine AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o /bin/owm ./cmd/mcp/owm

FROM alpine:3.21

RUN apk add --no-cache ca-certificates
COPY --from=builder /bin/owm /usr/local/bin/owm

EXPOSE 8080

ENTRYPOINT ["owm", "--transport", "http", "--addr", "0.0.0.0:8080"]
