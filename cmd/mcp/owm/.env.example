LOG_LEVEL=DEBUG

# OpenWeatherMap API key (required for both stdio and http transports)
OPENWEATHERMAP_API_KEY=

# OpenWeatherMap subscription plan (optional, defaults to true).
# When true (or absent), only free-tier endpoints are exposed:
#   - get_current_weather, get_weather_forecast (5-day/3-hour), geocode_city, reverse_geocode
# When set to false, pro-only endpoints replace the free forecast:
#   - get_hourly_forecast (4-day/1-hour), get_daily_forecast (16-day)
OPENWEATHERMAP_FREE_PLAN=true

# Shared secret for authenticating MCP HTTP clients (optional for http transport).
# The client must send this value in the X-API-Key header.
X_API_KEY=

# Public-facing base URL of this server.
# Required for Claude Desktop to connect (even without a reverse proxy).
# Example: https://mcp.example.com or https://xxxx.ngrok-free.app
BASE_URL=

# OAuth 2.0 Authorization Server URL (optional for http transport).
# When set, the server acts as an OAuth Resource Server and validates Bearer tokens.
OAUTH_AUTHORIZATION_SERVER=

# Expected audience (aud) claim in the JWT — typically the API identifier in Auth0.
OAUTH_AUDIENCE=

# Comma-separated list of OAuth scopes required to access the MCP endpoints (optional).
OAUTH_SCOPES=

# OAuth client secret (optional). Required only for confidential clients (Regular Web App
# in Auth0) when Claude desktopdoes not send the secret itself in the token request.
# For public clients (Single Page Application), leave this empty.
OAUTH_CLIENT_SECRET=
