LOG_LEVEL=DEBUG

# --- Authentication ---

# Shared secret for authenticating MCP HTTP clients (optional for http transport).
# The client must send this value in the X-API-Key header.
X_API_KEY=

# Public-facing base URL of this server.
# Required for Claude Desktop to connect (even without a reverse proxy).
# Example: https://mcp.example.com or https://xxxx.ngrok-free.app
BASE_URL=

# OAuth 2.0 Authorization Server URL (optional for http transport).
# When set, the server acts as an OAuth Resource Server and validates Bearer tokens.
OAUTH_AUTHORIZATION_SERVER=

# Expected audience (aud) claim in the JWT — typically the API identifier in Auth0.
OAUTH_AUDIENCE=

# Comma-separated list of OAuth scopes required to access the MCP endpoints (optional).
OAUTH_SCOPES=

# --- HTTP Security (optional, all values below are defaults) ---

# Maximum requests per second per client IP (default: 50).
HTTP_RATE_LIMIT=50

# Burst capacity per client IP (default: 50).
HTTP_RATE_BURST=50

# HTTP read timeout in seconds (default: 10). Protects against slow request attacks.
HTTP_READ_TIMEOUT=10

# HTTP write timeout in seconds (default: 30). Limits response write duration.
HTTP_WRITE_TIMEOUT=30

# HTTP idle connection timeout in seconds (default: 60). Closes inactive keep-alive connections.
HTTP_IDLE_TIMEOUT=60

# Comma-separated list of trusted proxy IPs or CIDRs (default: empty = trust all).
# When set, X-Forwarded-For is only read from requests originating from these addresses.
# Example: 172.17.0.1,10.0.0.0/8
HTTP_TRUSTED_PROXIES=
